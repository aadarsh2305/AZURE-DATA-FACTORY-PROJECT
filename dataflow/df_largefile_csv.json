{
	"name": "df_largefile_csv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_delimited_src",
						"type": "DatasetReference"
					},
					"name": "csvsource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adls_delimited_src",
						"type": "DatasetReference"
					},
					"name": "csvtarget"
				}
			],
			"transformations": [],
			"scriptLines": [
				"parameters{",
				"     p_partition_count as integer",
				"}",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> csvsource",
				"csvsource sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('roundRobin', ($p_partition_count))) ~> csvtarget"
			]
		}
	}
}