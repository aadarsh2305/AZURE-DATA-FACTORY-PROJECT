{
	"name": "df_json_dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_json_src",
						"type": "DatasetReference"
					},
					"name": "jsonsource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_adls_json_src",
						"type": "DatasetReference"
					},
					"name": "jsontarget"
				}
			],
			"transformations": [],
			"scriptLines": [
				"parameters{",
				"     p_partition_count as integer",
				"}",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> jsonsource",
				"jsonsource sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('roundRobin', ($p_partition_count))) ~> jsontarget"
			]
		}
	}
}