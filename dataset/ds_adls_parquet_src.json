{
	"name": "ds_adls_parquet_src",
	"properties": {
		"description": "for adls to sql",
		"linkedServiceName": {
			"referenceName": "ls_adls",
			"type": "LinkedServiceReference",
			"parameters": {
				"p_adls_url": "@dataset().p_adls_url"
			}
		},
		"parameters": {
			"p_container": {
				"type": "string"
			},
			"p_folder": {
				"type": "string"
			},
			"p_file": {
				"type": "string"
			},
			"p_adls_url": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().p_file",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@dataset().p_folder",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "@dataset().p_container",
					"type": "Expression"
				}
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}